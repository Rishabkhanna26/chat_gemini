# Core runtime
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_PROJECT.pooler.supabase.com:6543/postgres
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS

# Frontend -> backend
NEXT_PUBLIC_WHATSAPP_API_BASE=http://localhost:3001
NEXT_PUBLIC_WHATSAPP_SOCKET_URL=http://localhost:3001

# SMTP
SMTP_EMAIL=
SMTP_PASSWORD=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# AI (OpenRouter + WhatsApp AI behavior)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_FALLBACK_MODELS=openai/gpt-4o,google/gemini-2.0-flash-thinking-exp:free,qwen/qwen-2.5-72b-instruct:free
OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=
WHATSAPP_USE_LEGACY_AUTOMATION=false
WHATSAPP_AI_GREETING_REQUIRED=false
WHATSAPP_AI_HISTORY_LIMIT=6
WHATSAPP_AI_AUTO_LANGUAGE=true
AI_SETTINGS_TTL_MS=60000
ADMIN_PROFILE_TTL_MS=60000
ADMIN_CATALOG_TTL_MS=60000

# Razorpay / payments
WHATSAPP_PAYMENT_LINK=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR
RAZORPAY_PAYMENT_DESCRIPTION=WhatsApp order payment
RAZORPAY_CALLBACK_URL=http://localhost:3000/payment/success
RAZORPAY_CALLBACK_METHOD=get
PAYMENT_LINK_TIMER_ENABLED=true
PAYMENT_LINK_TIMER_POLL_SECONDS=30
PAYMENT_LINK_TIMER_BATCH_SIZE=10
PAYMENT_LINK_TIMER_RETRY_MINUTES=10

# Redis / session persistence tuning
ENABLE_SESSION_PERSISTENCE=false
REDIS_URL=
USER_IDLE_TTL_MS=21600000
CLEANUP_INTERVAL_MS=900000
CONVERSATION_STATE_RETENTION_DAYS=90
PERSISTENCE_RETRY_ATTEMPTS=3
PERSISTENCE_BATCH_WINDOW_MS=500
CIRCUIT_BREAKER_THRESHOLD=10
CIRCUIT_BREAKER_RESET_MS=60000
