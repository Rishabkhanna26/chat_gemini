# Database Configuration
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_PROJECT.pooler.supabase.com:6543/postgres

# Frontend Configuration
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001
PORT=3001

# WhatsApp Configuration
WHATSAPP_AUTH_PATH=.wwebjs_auth
WHATSAPP_MAX_SESSIONS=5
WHATSAPP_USER_IDLE_TTL_MS=21600000
WHATSAPP_SESSION_IDLE_TTL_MS=21600000
WHATSAPP_CLEANUP_INTERVAL_MS=900000
WHATSAPP_DUP_WINDOW_MS=10000
WHATSAPP_PAYMENT_LINK=

# Puppeteer Configuration (for production)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# AI Configuration (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4
OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=
WHATSAPP_USE_LEGACY_AUTOMATION=false
WHATSAPP_AI_GREETING_REQUIRED=false
WHATSAPP_AI_AUTO_LANGUAGE=true
WHATSAPP_AI_HISTORY_LIMIT=8

# Cache TTL Configuration
AI_SETTINGS_TTL_MS=60000
ADMIN_PROFILE_TTL_MS=60000
ADMIN_CATALOG_TTL_MS=60000

# Appointment Configuration
APPOINTMENT_START_HOUR=9
APPOINTMENT_END_HOUR=20
APPOINTMENT_SLOT_MINUTES=60
APPOINTMENT_WINDOW_MONTHS=3

# SMTP Configuration (for admin password emails)
SMTP_EMAIL=
SMTP_PASSWORD=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Redis Configuration (optional, for scaling)
REDIS_URL=

# Session State Persistence Configuration
ENABLE_SESSION_PERSISTENCE=false
USER_IDLE_TTL_MS=21600000
CLEANUP_INTERVAL_MS=900000
CONVERSATION_STATE_RETENTION_DAYS=90
PERSISTENCE_RETRY_ATTEMPTS=3
PERSISTENCE_BATCH_WINDOW_MS=500
CIRCUIT_BREAKER_THRESHOLD=10
CIRCUIT_BREAKER_RESET_MS=60000

# Security Configuration
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Monitoring & Logging
NODE_ENV=development
LOG_LEVEL=info
SENTRY_DSN=

# Debug Configuration
DEBUG_STORAGE_CHECK=false

# Public URLs (for production)
PUBLIC_URL=
RENDER_EXTERNAL_URL=
NEXT_PUBLIC_WHATSAPP_API_BASE=http://localhost:3001
NEXT_PUBLIC_WHATSAPP_SOCKET_URL=http://localhost:3001
